/* Gym Peso
   Cherri source for Cherri Playground.
   Input expected from the PWA: kilograms, e.g. 80.
   In Shortcuts, map the input to Health > Log Health Sample > Body Mass.
*/

#define color red
#define glyph scale

@kg = shortcutInput()
if @kg == "" {
  @kg = askForInput("Cual es tu peso en kg?", "80")
}

show("Registrar {@kg} kg en Apple Salud.")
/* Cherri Playground/Shortcuts step to add after export:
   Log Health Sample
   Type: Body Mass
   Value: {@kg}
   Unit: kg
*/
